{
  "name": "meal-planner",
  "version": "0.1.0",
  "description": "A web application for planning, shopping, prepping, and cooking weekly meals",
  "type": "module",
  "bin": {
    "mp": "./packages/cli/bin/mp.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:all": "pnpm cli:build && pnpm build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "cli:build": "cd packages/cli && npm run build",
    "cli": "node packages/cli/bin/mp.js",
    "check": "pnpm typecheck && pnpm lint && pnpm test:run",
    "check:all": "pnpm cli:build && pnpm check",
    "prepare": "husky"
  },
  "keywords": [
    "meal-planning",
    "meal-prep",
    "recipes",
    "cooking",
    "vegan"
  ],
  "author": "Matt Sullivan",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.16",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.3.0",
    "vitest": "^4.0.16",
    "yaml": "^2.8.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.26.2",
  "files": [
    "packages/cli/bin",
    "packages/cli/dist",
    "packages/cli/package.json"
  ],
  "dependencies": {
    "@cooklang/cooklang": "^0.17.2",
    "@tanstack/react-query": "^5.90.14",
    "@tanstack/react-query-devtools": "^5.91.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^13.1.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.11.0",
    "yaml": "^2.8.2",
    "zustand": "^5.0.9"
  }
}
